# Azure OpenAI — Chat completions (Key 1)
AZURE_API_KEY=your_azure_openai_key_here

# Azure OpenAI — Embeddings (Key 2)
AZURE_API_KEY_2=your_azure_openai_embeddings_key_here

# Azure OpenAI endpoint and version
AZURE_API_BASE=https://your-resource-name.openai.azure.com/
AZURE_API_VERSION=2024-10-21

# Deployment names (must match your Azure deployments)
AZURE_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Database (SQLite by default, swap to PostgreSQL for production)
DATABASE_URL=sqlite:///./teaching_app.db
# DATABASE_URL=postgresql://user:password@localhost:5432/vidyaai

# JWT secret — change this to a long random string in production
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# App settings
MAX_PREP_TIME_MINUTES=30
CHUNK_MAX_TOKENS=2000
CHUNK_OVERLAP_TOKENS=200

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:2708,http://localhost:3000
